
{% extends 'base.html.twig' %}

{% block title %}Gestion des Projets{% endblock %}

{% block header%}{% endblock %}


{% block body %}
<div class="max-w-7xl mx-auto px-4 py-10">
	<div class="flex flex-col md:flex-row md:items-center md:justify-between mb-10 gap-6">
		<div>
			<h1 class="text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-purple-600 via-pink-400 to-violet-700 mb-2 drop-shadow-lg">Gestion des Projets</h1>
			<p class="text-gray-400 text-lg mb-4 italic">Retrouve tous tes projets, modifie-les, supprime-les ou ajoute-en de nouveaux facilement.</p>
		</div>
		<div class="flex gap-4 items-center">
			<a href="{{ path('admin_dashboard') }}" class="inline-flex items-center gap-2 px-7 py-3 bg-gradient-to-br from-violet-500 via-purple-500 to-pink-500 text-white font-bold rounded-full shadow-lg hover:scale-105 hover:from-violet-600 hover:to-pink-600 transition-all duration-300 border-2 border-white">
				<i class="fas fa-tachometer-alt text-lg"></i>
				<span class="hidden md:inline">Tableau de bord</span>
			</a>
			<a href="{{ path('admin_project_create') }}" class="inline-flex items-center gap-2 px-7 py-3 bg-gradient-to-br from-pink-500 via-purple-600 to-violet-700 text-white font-bold rounded-full shadow-lg hover:scale-105 hover:from-pink-600 hover:to-violet-800 transition-all duration-300 border-2 border-white">
				<i class="fas fa-plus text-lg"></i>
				<span class="hidden md:inline">Ajouter un projet</span>
			</a>
		</div>
	</div>


	{% for message in app.flashes('success') %}
		<div class="mb-4 px-4 py-2 bg-green-100 text-green-800 rounded shadow">{{ message }}</div>
	{% endfor %}
	{% for message in app.flashes('info') %}
		<div class="mb-4 px-4 py-2 bg-blue-100 text-blue-800 rounded shadow">{{ message }}</div>
	{% endfor %}
	{% for message in app.flashes('error') %}
		<div class="mb-4 px-4 py-2 bg-red-100 text-red-800 rounded shadow">{{ message }}</div>
	{% endfor %}
	<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
	{% for projet in pagination %}
		<div class="bg-white border-2 border-purple-100 rounded-2xl shadow-xl p-7 flex flex-col justify-between hover:shadow-2xl transition-all duration-500 hover:-translate-y-1">
			{% if projet.image %}
				<img src="{{ asset('assets/' ~ projet.image) }}" alt="Image du projet {{ projet.titre }}" class="w-full h-44 object-cover rounded-xl mb-5 border-2 border-purple-200" />
			{% else %}
				<div class="w-full h-44 flex items-center justify-center bg-gradient-to-br from-purple-400 via-violet-500 to-indigo-500 rounded-xl mb-5 border-2 border-purple-200">
					<span class="text-white text-3xl font-bold">{{ projet.titre|slice(0, 2)|upper }}</span>
				</div>
			{% endif %}
			<div>
				<h2 class="text-2xl font-bold text-purple-700 mb-2">{{ projet.titre }}</h2>
				<p class="text-gray-600 mb-3">{{ projet.description|length > 120 ? projet.description|slice(0,120) ~ '...' : projet.description }}</p>
				<div class="flex flex-wrap gap-2 mb-2">
					<span class="inline-block px-3 py-1 text-xs bg-purple-50 text-purple-700 rounded">Début : {{ projet.dateDebut ? projet.dateDebut|date('d/m/Y') : '-' }}</span>
					<span class="inline-block px-3 py-1 text-xs bg-purple-50 text-purple-700 rounded">Fin : {{ projet.dateFin ? projet.dateFin|date('d/m/Y') : '-' }}</span>
				</div>
				<div class="flex flex-wrap gap-2 mb-2">
					<span class="inline-block px-3 py-1 text-xs bg-gradient-to-r from-purple-100 to-violet-100 text-purple-800 rounded-full">Type : {{ projet.typeProjet }}</span>
					<span class="inline-block px-3 py-1 text-xs bg-purple-100 text-purple-800 rounded-full">État : {{ projet.etat }}</span>
					{% if projet.visible %}
						<span class="inline-block px-3 py-1 text-xs bg-green-100 text-green-800 rounded-full">Visible</span>
					{% else %}
						<span class="inline-block px-3 py-1 text-xs bg-red-100 text-red-800 rounded-full">Invisible</span>
					{% endif %}
				</div>
			</div>
			<div class="flex gap-2 mt-3 mb-1 items-center">
				<a href="{{ path('admin_project_edit', {id: projet.id}) }}"
				   class="flex-1 px-5 py-2 bg-gradient-to-r from-purple-600 to-violet-600 text-white rounded-full shadow-lg text-base text-center font-semibold transition-all duration-300 hover:scale-105 hover:from-purple-700 hover:to-violet-800 hover:shadow-2xl focus:outline-none focus:ring-2 focus:ring-purple-400">
					<i class="fas fa-edit mr-2"></i>Modifier
				</a>
				<form method="post" action="{{ path('admin_project_delete', {id: projet.id}) }}" class="flex-1" onsubmit="return confirm('Voulez-vous vraiment supprimer ce projet ?');">
					<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ projet.id) }}">
					<button type="submit"
							class="w-full px-5 py-2 bg-gradient-to-r from-pink-500 to-red-600 text-white rounded-full shadow-lg text-base text-center font-semibold transition-all duration-300 hover:scale-105 hover:from-pink-600 hover:to-red-700 hover:shadow-2xl focus:outline-none focus:ring-2 focus:ring-pink-400">
						<i class="fas fa-trash-alt mr-2"></i>Supprimer
					</button>
				</form>
			</div>
		</div>
	{% else %}
		<div class="col-span-full text-center text-purple-400 py-16 text-xl font-semibold">Aucun projet trouvé.</div>
	{% endfor %}
	</div>

	{# Pagination personnalisée #}
	<div class="flex justify-center mt-10">
		<nav class="inline-flex rounded-md shadow-sm" aria-label="Pagination">
			{% if pagination.currentPageNumber > 1 %}
				<a href="{{ path(app.request.attributes.get('_route'), app.request.query.all|merge({'page': pagination.currentPageNumber - 1})) }}"
				   class="px-4 py-2 bg-purple-100 text-purple-700 rounded-l hover:bg-purple-200 font-semibold">&laquo; Précédent</a>
			{% else %}
				<span class="px-4 py-2 bg-gray-100 text-gray-400 rounded-l cursor-not-allowed">&laquo; Précédent</span>
			{% endif %}

			{% for page in 1..pagination.pageCount %}
				{% if page == pagination.currentPageNumber %}
					<span class="px-4 py-2 bg-purple-500 text-white font-bold">{{ page }}</span>
				{% else %}
					<a href="{{ path(app.request.attributes.get('_route'), app.request.query.all|merge({'page': page})) }}"
					   class="px-4 py-2 bg-purple-100 text-purple-700 hover:bg-purple-200 font-semibold">{{ page }}</a>
				{% endif %}
			{% endfor %}

			{% if pagination.currentPageNumber < pagination.pageCount %}
				<a href="{{ path(app.request.attributes.get('_route'), app.request.query.all|merge({'page': pagination.currentPageNumber + 1})) }}"
				   class="px-4 py-2 bg-purple-100 text-purple-700 rounded-r hover:bg-purple-200 font-semibold">Suivant &raquo;</a>
			{% else %}
				<span class="px-4 py-2 bg-gray-100 text-gray-400 rounded-r cursor-not-allowed">Suivant &raquo;</span>
			{% endif %}
		</nav>
	</div>
</div>
{% endblock %}
