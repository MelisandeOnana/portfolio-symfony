{% extends 'base.html.twig' %}

{% block title %}Modifier {{ projet.titre }} - Administration{% endblock %}
{% block header%}{% endblock %}

{% block body %}
<section class="relative bg-gradient-to-r from-purple-500 via-violet-600 to-purple-800 text-white py-16 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
        <svg class="w-full h-full opacity-20" viewBox="0 0 1440 320"><defs><linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" style="stop-color:#a78bfa;stop-opacity:1" /><stop offset="100%" style="stop-color:#7c3aed;stop-opacity:1" /></linearGradient></defs><path fill="url(#grad1)" fill-opacity="1" d="M0,160L60,165.3C120,171,240,181,360,165.3C480,149,600,107,720,117.3C840,128,960,192,1080,186.7C1200,181,1320,107,1380,69.3L1440,32L1440,0L1380,0C1320,0,1200,0,1080,0C960,0,840,0,720,0C600,0,480,0,360,0C240,0,120,0,60,0L0,0Z"></path></svg>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-purple-200 via-white to-violet-300 mb-4 drop-shadow-lg">Modifier le projet</h1>
        <p class="text-lg font-semibold text-white/80 mb-2">{{ projet.titre }}</p>
        <div class="inline-block px-6 py-2 bg-white/10 rounded-full text-purple-100 font-medium shadow-lg backdrop-blur-sm">
            <i class="fas fa-pen mr-2"></i>Administration
        </div>
    </div>
</section>

<section class="py-12 bg-gradient-to-br from-purple-100 to-white min-h-screen">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="relative flex flex-col items-center justify-center gap-10">
            {% if projet.image %}
                <div class="relative w-80 h-80 flex items-center justify-center mb-10">
                    <span class="absolute inset-0 rounded-full border-8 border-purple-200 animate-spin-slow pointer-events-none"></span>
                    <img src="{{ asset('assets/' ~ projet.image) }}" alt="Image du projet" class="w-64 h-64 object-cover rounded-full shadow-2xl border-4 border-purple-400 transition-transform duration-500 hover:scale-105 hover:shadow-purple-500/50" style="box-shadow:0 0 100px 20px #a78bfa55;" />
                    <div class="absolute inset-0 rounded-full bg-gradient-to-br from-purple-400 via-violet-500 to-purple-800 opacity-40 blur-2xl"></div>
                </div>
                <div class="text-center mb-8">
                        <h2 class="text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-purple-500 via-violet-600 to-purple-800 drop-shadow-lg mb-2">{{ projet.titre }}</h2>
                        <p class="text-lg text-purple-700 font-semibold">{{ projet.typeProjet }}
                                {% if projet.dateDebut or projet.dateFin %}
                                    •
                                    {% if projet.dateDebut %}{{ projet.dateDebut|date('d F Y')|replace({'January':'janvier','February':'février','March':'mars','April':'avril','May':'mai','June':'juin','July':'juillet','August':'août','September':'septembre','October':'octobre','November':'novembre','December':'décembre'}) }}{% endif %}
                                    {% if projet.dateFin %} – {{ projet.dateFin|date('d F Y')|replace({'January':'janvier','February':'février','March':'mars','April':'avril','May':'mai','June':'juin','July':'juillet','August':'août','September':'septembre','October':'octobre','November':'novembre','December':'décembre'}) }}{% endif %}
                                {% endif %}
                        </p>
                </div>
            {% endif %}
            <div class="w-full md:w-2/3 bg-white border-2 border-purple-100 rounded-2xl shadow-xl p-8 animate-fade-in relative z-20">
                {% set page = app.request.query.get('page', 1) %}
                {{ form_start(form, {'attr': {'class': 'space-y-8'}}) }}
                <input type="hidden" name="page" value="{{ page }}" />
                    {{ form_errors(form) }}
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div>
                            <label class="flex items-center gap-2 text-purple-700 font-medium mb-2"><i class="fas fa-heading"></i>{{ form_label(form.titre) }}</label>
                            {{ form_widget(form.titre) }}
                            {{ form_errors(form.titre) }}
                        </div>
                        <div>
                            <label class="flex items-center gap-2 text-purple-700 font-medium mb-2"><i class="fas fa-layer-group"></i>{{ form_label(form.typeProjet) }}</label>
                            {{ form_widget(form.typeProjet) }}
                            {{ form_errors(form.typeProjet) }}
                        </div>
                        <div class="md:col-span-2">
                            <label class="flex items-center gap-2 text-purple-700 font-medium mb-2"><i class="fas fa-align-left"></i>{{ form_label(form.description) }}</label>
                            {{ form_widget(form.description) }}
                            {{ form_errors(form.description) }}
                        </div>
                        <div class="md:col-span-2">
                                <label class="flex items-center gap-2 text-purple-700 font-medium mb-2"><i class="fas fa-image"></i>Image du projet</label>
                                {% if projet is defined and projet.image %}
                                    <div class="mb-4">
                                        <span class="block text-xs text-purple-400 mb-1">Image actuelle :</span>
                                        <img src="{{ asset('assets/' ~ projet.image) }}" alt="Image du projet" class="max-h-40 rounded-lg border border-purple-200 shadow" />
                                        <div class="mt-2">
                                            <label class="inline-flex items-center gap-2 text-purple-700 font-medium">
                                                <input type="checkbox" name="delete_image" value="1" class="form-checkbox text-purple-600" />
                                                <span>Supprimer l'image</span>
                                            </label>
                                        </div>
                                    </div>
                                {% endif %}
                                {{ form_widget(form.image, {'attr': {'onchange': 'previewImage(event)'}}) }}
                                {{ form_errors(form.image) }}
                                <div id="image-preview" class="mt-4"></div>
                        </div>
                        <div>
                            <label class="flex items-center gap-2 text-purple-700 font-medium mb-2"><i class="fas fa-calendar-alt"></i>{{ form_label(form.dateDebut) }}</label>
                            {{ form_widget(form.dateDebut) }}
                            {{ form_errors(form.dateDebut) }}
                        </div>
                        <div>
                            <label class="flex items-center gap-2 text-purple-700 font-medium mb-2"><i class="fas fa-calendar-check"></i>{{ form_label(form.dateFin) }}</label>
                            {{ form_widget(form.dateFin) }}
                            {{ form_errors(form.dateFin) }}
                        </div>
                        <div>
                            <label class="flex items-center gap-2 text-purple-700 font-medium mb-2"><i class="fas fa-tasks"></i>{{ form_label(form.etat) }}</label>
                            {{ form_widget(form.etat) }}
                            {{ form_errors(form.etat) }}
                        </div>
                        <div>
                            <label class="flex items-center gap-2 text-purple-700 font-medium mb-2"><i class="fas fa-eye"></i>{{ form_label(form.visible) }}</label>
                            {{ form_widget(form.visible) }}
                            {{ form_errors(form.visible) }}
                        </div>
                        <div>
                            <label class="flex items-center gap-2 text-purple-700 font-medium mb-2"><i class="fas fa-link"></i>{{ form_label(form.lien) }}</label>
                            {{ form_widget(form.lien) }}
                            {{ form_errors(form.lien) }}
                        </div>
                        <div>
                            <label class="flex items-center gap-2 text-purple-700 font-medium mb-2"><i class="fab fa-github"></i>{{ form_label(form.githubLinks) }}</label>
                            {{ form_widget(form.githubLinks) }}
                            {{ form_errors(form.githubLinks) }}
                        </div>
                        <div>
                            <label class="flex items-center gap-2 text-purple-700 font-medium mb-2"><i class="fas fa-file-upload"></i>{{ form_label(form.documents) }}</label>
                            {{ form_widget(form.documents) }}
                            {{ form_errors(form.documents) }}
                        </div>
                    </div>
                    <div>
                        <label class="flex items-center gap-2 text-purple-700 font-medium mb-2"><i class="fas fa-microchip"></i>{{ form_label(form.technologies) }}</label>
                        <div class="flex flex-wrap gap-3 p-4 border border-purple-200 rounded-lg max-h-64 overflow-y-auto">
                            {% for child in form.technologies %}
                                <label class="cursor-pointer">
                                    {{ form_widget(child, {'attr': {'class': 'hidden peer'}}) }}
                                    <span class="px-4 py-2 rounded-full border border-purple-200 bg-purple-50 text-purple-700 font-medium transition
                                        peer-checked:bg-gradient-to-r peer-checked:from-purple-500 peer-checked:to-violet-500 peer-checked:text-white
                                        hover:bg-purple-100 hover:text-purple-900">
                                        {{ child.vars.label }}
                                    </span>
                                </label>
                            {% endfor %}
                        </div>
                        {{ form_errors(form.technologies) }}
                    </div>
                    <div class="flex justify-between items-center pt-8 border-t border-purple-100 mt-8">
                        <a href="{{ path('admin_project_list') }}"
                           class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-purple-400 to-violet-500 text-white rounded-full hover:from-purple-500 hover:to-violet-600 transition-colors duration-300 font-semibold shadow-lg">
                            <i class="fas fa-arrow-left mr-2"></i>Annuler
                        </a>
                        {{ form_widget(form.save, {'attr': {'class': 'inline-flex items-center px-8 py-3 bg-gradient-to-r from-purple-600 to-violet-600 text-white rounded-full hover:from-purple-700 hover:to-violet-700 font-semibold transition-colors duration-300 shadow-lg'}}) }}
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</section>

<script>
function previewImage(event) {
    const input = event.target;
    const preview = document.getElementById('image-preview');
    preview.innerHTML = '';
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
            preview.innerHTML = '<img src="' + e.target.result + '" class="max-h-40 rounded-lg border border-purple-200 shadow mt-2" />';
        }
        reader.readAsDataURL(input.files[0]);
    }
}
</script>
{% endblock %}

