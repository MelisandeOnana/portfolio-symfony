{% extends 'base.html.twig' %}

{% block title %}Édition du profil{% endblock %}

{% block body %}
<section class="max-w-xl mx-auto mt-12 p-8 bg-white rounded-2xl shadow-lg">
    <h2 class="text-2xl font-bold mb-6 text-indigo-700">Modifier mon profil</h2>

    {{ form_start(form) }}
        <div class="space-y-4">
            {{ form_row(form.prenom) }}
            {{ form_row(form.nom) }}
            {{ form_row(form.email) }}
            
            <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-4">
                <div class="flex items-center">
                    <svg class="w-4 h-4 text-blue-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
                    </svg>
                    <span class="text-blue-800 text-sm font-medium">
                        Laissez les champs mot de passe vides si vous ne souhaitez pas le modifier.
                    </span>
                </div>
            </div>
            
            <div class="space-y-4">
                <div class="relative">
                    {{ form_label(form.plainPassword.first) }}
                    <div class="relative flex items-center w-full">
                        {{ form_widget(form.plainPassword.first, {
                            'attr': {
                                'class': 'w-full h-12 pr-12 pl-4 py-3 border border-purple-400 text-purple-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500 bg-purple-50 placeholder-purple-300',
                                'autocomplete': 'new-password'
                            }
                        }) }}
                        <button
                            type="button"
                            class="absolute right-4 top-1/2 -translate-y-1/2 px-2 focus:outline-none toggle-password"
                            data-target="{{ form.plainPassword.first.vars.id }}"
                            aria-label="Afficher/Masquer le mot de passe"
                            tabindex="-1"
                            style="background:transparent;border:none;"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" fill="#bbb" stroke="#bbb" class="w-5 h-5" viewBox="0 0 128 128">
                                <path d="M64 104C22.127 104 1.367 67.496.504 65.943a4 4 0 0 1 0-3.887C1.367 60.504 22.127 24 64 24s62.633 36.504 63.496 38.057a4 4 0 0 1 0 3.887C126.633 67.496 105.873 104 64 104zM8.707 63.994C13.465 71.205 32.146 96 64 96c31.955 0 50.553-24.775 55.293-31.994C114.535 56.795 95.854 32 64 32 32.045 32 13.447 56.775 8.707 63.994zM64 88c-13.234 0-24-10.766-24-24s10.766-24 24-24 24 10.766 24 24-10.766 24-24 24zm0-40c-8.822 0-16 7.178-16 16s7.178 16 16 16 16-7.178 16-16-7.178-16-16-16z" data-original="#000000"></path>
                            </svg>
                        </button>
                    </div>
                    {{ form_errors(form.plainPassword.first) }}
                </div>
                <div class="relative">
                    {{ form_label(form.plainPassword.second) }}
                    <div class="relative flex items-center w-full">
                        {{ form_widget(form.plainPassword.second, {
                            'attr': {
                                'class': 'w-full h-12 pr-12 pl-4 py-3 border border-purple-400 text-purple-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500 bg-purple-50 placeholder-purple-300',
                                'autocomplete': 'new-password'
                            }
                        }) }}
                        <button
                            type="button"
                            class="absolute right-4 top-1/2 -translate-y-1/2 px-2 focus:outline-none toggle-password"
                            data-target="{{ form.plainPassword.second.vars.id }}"
                            aria-label="Afficher/Masquer le mot de passe"
                            tabindex="-1"
                            style="background:transparent;border:none;"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" fill="#bbb" stroke="#bbb" class="w-5 h-5" viewBox="0 0 128 128">
                                <path d="M64 104C22.127 104 1.367 67.496.504 65.943a4 4 0 0 1 0-3.887C1.367 60.504 22.127 24 64 24s62.633 36.504 63.496 38.057a4 4 0 0 1 0 3.887C126.633 67.496 105.873 104 64 104zM8.707 63.994C13.465 71.205 32.146 96 64 96c31.955 0 50.553-24.775 55.293-31.994C114.535 56.795 95.854 32 64 32 32.045 32 13.447 56.775 8.707 63.994zM64 88c-13.234 0-24-10.766-24-24s10.766-24 24-24 24 10.766 24 24-10.766 24-24 24zm0-40c-8.822 0-16 7.178-16 16s7.178 16 16 16 16-7.178 16-16-7.178-16-16-16z" data-original="#000000"></path>
                            </svg>
                        </button>
                    </div>
                    {{ form_errors(form.plainPassword.second) }}
                </div>
            </div>
        </div>
        <button type="submit" class="mt-6 bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2 rounded-xl font-semibold transition-all duration-300">Enregistrer</button>
        <a href="{{ path('admin_dashboard') }}" class="inline-block mt-6 bg-gray-600 hover:bg-gray-700 text-white px-6 py-2 rounded-xl font-semibold transition-all duration-300 ml-4 text-decoration-none">Retour</a>
    {{ form_end(form) }}
    <script>
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.toggle-password').forEach(function(btn) {
            btn.addEventListener('click', function () {
                const inputId = btn.getAttribute('data-target');
                const input = document.getElementById(inputId);
                if (input) {
                    const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
                    input.setAttribute('type', type);
                }
            });
        });
    });
    </script>
</section>
{% endblock %}
