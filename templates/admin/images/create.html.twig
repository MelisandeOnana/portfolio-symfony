{% extends 'base.html.twig' %}

{% block title %}Ajouter une image à un projet{% endblock %}

{% block header%}{% endblock %}

{% block body %}
<div class="max-w-xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-purple-500 to-violet-600 mb-6">Ajouter une image à un projet</h1>
    {{ form_start(form, {'attr': {'class': 'flex flex-col gap-6 bg-purple-50 p-6 rounded-xl shadow', 'enctype': 'multipart/form-data'}}) }}
        {{ form_row(form.projet, {'attr': {'class': 'w-full px-4 py-2 border border-purple-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-400'}, 'label_attr': {'class': 'block text-purple-700 font-semibold mb-2'}}) }}
        {{ form_row(form.image, {'attr': {'class': 'w-full px-4 py-2 border border-purple-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-400'}, 'label_attr': {'class': 'block text-purple-700 font-semibold mb-2'}}) }}
        <button type="submit" class="px-6 py-2 bg-gradient-to-r from-purple-500 to-pink-600 text-white font-bold rounded-full shadow hover:from-purple-600 hover:to-pink-700 transition-all duration-300">Ajouter l'image</button>
    {{ form_end(form) }}
</div>
{% endblock %}
