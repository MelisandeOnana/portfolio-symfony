{% extends 'base.html.twig' %}

{% block title %}Dashboard - Administration{% endblock %}

{% block header %}{% endblock %}

{% block body %}
<section class="bg-gradient-to-br from-indigo-900 via-purple-900 to-pink-800 text-white py-16 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="flex flex-col md:flex-row justify-between items-center mb-10">
            <div class="flex items-center space-x-4">
                <div class="w-16 h-16 rounded-full bg-gradient-to-br from-purple-400 to-pink-400 flex items-center justify-center shadow-lg">
                    <i class="fas fa-user text-white text-3xl"></i>
                </div>
                <div>
                    <h2 class="text-2xl font-bold">{{ app.user ? app.user.prenom ~ ' ' ~ app.user.nom : 'Guest' }}</h2>
                    <p class="text-xs text-purple-300">Dernière connexion: {{ "now"|date("d/m/Y à H:i") }}</p>
                </div>
            </div>
            <div class="flex flex-col md:flex-row items-center space-y-4 md:space-y-0 md:space-x-4 mt-6 md:mt-0">
                <a href="{{ path('admin_profile_edit') }}" class="bg-indigo-500 hover:bg-indigo-600 text-white px-6 py-3 rounded-xl font-semibold transition-all duration-300 shadow-lg flex items-center">
                    <i class="fas fa-user-edit mr-2"></i> Gérer mon profil
                </a>
                <a href="{{ path('homepage') }}" class="bg-gradient-to-r from-purple-400 to-pink-500 hover:from-purple-500 hover:to-pink-600 text-white px-6 py-3 rounded-xl font-semibold transition-all duration-300 shadow-lg flex items-center">
                    <i class="fas fa-home mr-2"></i> Retour au site
                </a>
                <a href="{{ path('logout') }}" class="bg-red-500 hover:bg-red-600 text-white px-6 py-3 rounded-xl font-semibold transition-all duration-300 shadow-lg flex items-center">
                    <i class="fas fa-sign-out-alt mr-2"></i> Déconnexion
                </a>
            </div>
        </div>
        {% for message in app.flashes('success') %}
            <div class="mb-6 p-4 rounded-xl bg-purple-100 text-purple-800 border border-purple-300 shadow">
                <i class="fas fa-check-circle mr-2"></i>{{ message }}
            </div>
        {% endfor %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
            <div class="bg-white rounded-2xl shadow-lg p-8 border-l-4 border-blue-500 flex flex-col items-start group hover:-translate-y-1 transition">
                <div class="flex items-center mb-4">
                    <div class="bg-blue-100 p-3 rounded-xl mr-3">
                        <i class="fas fa-folder-open text-blue-500 text-2xl"></i>
                    </div>
                    <span class="text-lg font-semibold text-gray-700">Projets</span>
                </div>
                <span class="text-4xl font-bold text-blue-600 mb-2">{{ projets|length }}</span>
                <a href="{{ path('admin_project_list') }}" class="text-blue-600 hover:text-blue-800 font-medium mt-2 flex items-center group">
                    Gérer <i class="fas fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform"></i>
                </a>
            </div>
            <div class="bg-white rounded-2xl shadow-lg p-8 border-l-4 border-purple-500 flex flex-col items-start group hover:-translate-y-1 transition">
                <div class="flex items-center mb-4">
                    <div class="bg-purple-100 p-3 rounded-xl mr-3">
                        <i class="fas fa-code text-purple-500 text-2xl"></i>
                    </div>
                    <span class="text-lg font-semibold text-gray-700">Technologies</span>
                </div>
                <span class="text-4xl font-bold text-purple-600 mb-2">{{ technologies|length }}</span>
                <a href="{{ path('admin_technology_list') }}" class="text-purple-600 hover:text-purple-800 font-medium mt-2 flex items-center group">
                    Gérer <i class="fas fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform"></i>
                </a>
            </div>
            <div class="bg-white rounded-2xl shadow-lg p-8 border-l-4 border-green-500 flex flex-col items-start group hover:-translate-y-1 transition">
                <div class="flex items-center mb-4">
                    <div class="bg-green-100 p-3 rounded-xl mr-3">
                        <i class="fas fa-envelope text-green-500 text-2xl"></i>
                    </div>
                    <span class="text-lg font-semibold text-gray-700">Messages</span>
                </div>
                <span class="text-4xl font-bold text-green-600 mb-2">{{ demandesContact|length }}</span>
                <a href="{{ path('admin_contact_list') }}" class="text-green-600 hover:text-green-800 font-medium mt-2 flex items-center group">
                    Gérer <i class="fas fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform"></i>
                </a>
            </div>
            <div class="bg-white rounded-2xl shadow-lg p-8 border-l-4 border-pink-500 flex flex-col items-start group hover:-translate-y-1 transition">
                <div class="flex items-center mb-4">
                    <div class="bg-pink-100 p-3 rounded-xl mr-3">
                        <i class="fas fa-users text-pink-500 text-2xl"></i>
                    </div>
                    <span class="text-lg font-semibold text-gray-700">Images</span>
                </div>
                <span class="text-4xl font-bold text-pink-600 mb-2">{{ images|length }}</span>
                <a href="{{ path('admin_image_list') }}" class="text-pink-600 hover:text-pink-800 font-medium mt-2 flex items-center group">
                    Gérer <i class="fas fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform"></i>
                </a>
            </div>
        </div>
    </div>
</section>
{% endblock %}